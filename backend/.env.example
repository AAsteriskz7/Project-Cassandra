# LLM provider: "gemini" (AI Studio, API-key, free tier) or "vertex" (Vertex AI, GCP billing)
LLM_PROVIDER=gemini

# --- Gemini / AI Studio (LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Vertex AI (LLM_PROVIDER=vertex) ---
# Billed to the project's GCP billing account (e.g. your TryGCP credit).
# Auth: run `gcloud auth application-default login` once.
VERTEX_PROJECT=your_gcp_project_id
VERTEX_LOCATION=us-central1

TARGET_MODEL=gemini-2.5-flash
SWARM_MODEL=gemini-2.5-flash
DIVERGENCE_THRESHOLD=0.6
NUM_PERTURBATIONS=3
EMBEDDING_MODEL=all-MiniLM-L6-v2
